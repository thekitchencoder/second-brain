# ── Container environment ──────────────────────────────────────────────────────
# Passed into the running container via env_file: in docker-compose.yml.
EMBEDDING_BASE_URL=http://model-runner.docker.internal/engines/llama.cpp/v1
EMBEDDING_MODEL=ai/mxbai-embed-large:latest
CHAT_BASE_URL=http://model-runner.docker.internal/engines/llama.cpp/v1
CHAT_MODEL=ai/llama3.2:latest
OPENAI_API_KEY=local

# NOTE: BRAIN_HOST_PATH is NOT set here — it must be exported in your shell
# before running docker compose, as .env is not reliably read for compose
# variable interpolation across all platforms.
# Add to ~/.zshrc:  export BRAIN_HOST_PATH=~/Documents/brain

# ── Code-Server UI ─────────────────────────────────────────────────────────────
# Browser-accessible VS Code at http://localhost:8080 (no password — single user)
CODE_SERVER_PORT=8080

# ── Claude Code credentials ────────────────────────────────────────────────────
# Claude Code runs in the integrated terminal. Set credentials here (not in your
# shell) because restart:unless-stopped makes shell env-var passthrough unreliable.
#
# Anthropic API (claude.ai account):
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
#
# AWS Bedrock (work/enterprise):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=
# AWS_REGION=
