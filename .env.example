# ── Container environment ──────────────────────────────────────────────────────
# This is a reference file. You don't need to copy it manually:
#   - brain-init can generate a .env inside your vault with guided presets
#   - Or create <vault>/.env yourself — the container sources it on startup
#   - Or use docker-compose.yml with env_file (for development setups)
#
# Passed into the running container via env_file: in docker-compose.yml.
EMBEDDING_BASE_URL=http://model-runner.docker.internal/engines/llama.cpp/v1
EMBEDDING_MODEL=ai/mxbai-embed-large:latest
OPENAI_API_KEY=local

# NOTE: BRAIN_HOST_PATH is NOT set here — it must be exported in your shell
# before running docker compose, as .env is not reliably read for compose
# variable interpolation across all platforms.
# Add to ~/.zshrc:  export BRAIN_HOST_PATH=~/Documents/brain

# ── Code-Server UI ─────────────────────────────────────────────────────────────
# Browser-accessible VS Code at http://localhost:8080 (no password — single user)
CODE_SERVER_PORT=8080

# ── Web search (optional) ──────────────────────────────────────────────────────
# Enables the brave-search MCP server in Claude Code. Free tier: 2k queries/month.
# Get a key at https://brave.com/search/api/
# BRAVE_API_KEY=

# ── Claude Code ────────────────────────────────────────────────────────────────
# These are picked up directly from the container environment — no rebuild needed,
# just restart the container after changing them.
ANTHROPIC_BASE_URL=http://model-runner.docker.internal
ANTHROPIC_AUTH_TOKEN=ollama
ANTHROPIC_MODEL=docker.io/ai/qwen2.5:7B-Q4_0
#
# To use real Claude instead, replace the above with:
# ANTHROPIC_BASE_URL=          # leave unset
# ANTHROPIC_AUTH_TOKEN=        # claude.ai subscription token
# ANTHROPIC_MODEL=             # leave unset to use Claude's default
