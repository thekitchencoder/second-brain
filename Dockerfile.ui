ARG BASE_IMAGE=kitchencoder/second-brain:latest
FROM ${BASE_IMAGE}

ARG CODE_SERVER_VERSION=4.114.1

LABEL version="1.0.2"

USER root

# Install code-server via official installer (pre-built release, avoids npm extraction issues)
RUN curl -fsSL https://code-server.dev/install.sh | sh -s -- --version ${CODE_SERVER_VERSION}

# Claude Code CLI (UI-only — used from the code-server terminal)
RUN npm install -g @anthropic-ai/claude-code

USER coder
RUN for ext in \
        foam.foam-vscode \
        yzhang.markdown-all-in-one \
        bierner.markdown-preview-github-styles \
        bierner.markdown-mermaid \
        zaaack.markdown-editor; do \
    installed=false; \
    for i in 1 2 3; do \
        code-server --install-extension "$ext" && installed=true && break; \
        echo "Retry $i for $ext..."; \
        sleep 5; \
    done; \
    [ "$installed" = "true" ] || { echo "Failed to install $ext after 3 attempts"; exit 1; }; \
    done

COPY --chown=coder:coder code-server/settings.json /home/coder/.local/share/code-server/User/settings.json
COPY --chown=coder:coder code-server/keybindings.json /home/coder/.local/share/code-server/User/keybindings.json

EXPOSE 7778

ENTRYPOINT ["/usr/local/lib/brain-tools/entrypoint-ui.sh"]
