{
  "mcpServers": {
    "brain": {
      "command": "brain-mcp-server"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    }
  },
  "projects": {
    "/brain": {
      "hasTrustDialogAccepted": true,
      "allowedTools": [
        "mcp__brain__brain_search",
        "mcp__brain__brain_query",
        "mcp__brain__brain_read",
        "mcp__brain__brain_write",
        "mcp__brain__brain_create",
        "mcp__brain__brain_templates",
        "mcp__brain__brain_edit",
        "mcp__brain__brain_related",
        "mcp__brain__brain_backlinks"
      ]
    }
  }
}
