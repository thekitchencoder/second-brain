def _read_env_value(env_path, key):
    """Read a single variable's value from a .env file. Returns '' if not found."""
    if not os.path.isfile(env_path):
        return ""
    with open(env_path) as f:
        for line in f:
            line = line.strip()
            if line.startswith(f"{key}="):
                value = line[len(key) + 1:]
                # Strip inline comments (space + #)
                if "  #" in value:
                    value = value[:value.index("  #")].strip()
                return value
    return ""


def _count_md_files(path):
    """Count markdown files in the vault (non-recursive in hidden dirs)."""
    count = 0
    for root, dirs, files in os.walk(path):
        # Skip hidden directories
        dirs[:] = [d for d in dirs if not d.startswith(".")]
        count += sum(1 for f in files if f.endswith(".md"))
    return count


