def run_wizard(brain_path):
    """Interactive setup wizard — guides user through configuration."""
    md_count = _count_md_files(brain_path)
    is_fresh = md_count == 0 and not os.path.isdir(os.path.join(brain_path, ".zk"))

    print()
    print("=" * 60)
    print("  Second Brain Setup")
    print("=" * 60)
    print()

    if is_fresh:
        print(f"  Vault: {brain_path} (empty — fresh start)")
    else:
        print(f"  Vault: {brain_path} ({md_count} notes found)")
    print()

    # Step 1: Core init (always)
    print("[1/5] Initialising brain tools...")
    init_core(brain_path)
    init_vault_skills(brain_path)
    stage_brain_plugin(brain_path)
    print()

    # Step 2: ACE folders
    print("[2/5] Folder structure")
    existing = [f for f in ACE_FOLDERS if os.path.isdir(os.path.join(brain_path, f))]
    missing = [f for f in ACE_FOLDERS if f not in existing]

    if not missing:
        print(f"  All ACE folders already exist: {', '.join(ACE_FOLDERS)}")
    else:
        default = "y" if is_fresh else "n"
        print(f"  The ACE structure organises notes into: {', '.join(ACE_FOLDERS)}")
        if existing:
            print(f"  Already exist: {', '.join(existing)}")
            print(f"  Missing: {', '.join(missing)}")
        if _ask("  Create folder structure?", default=default):
            init_ace_folders(brain_path)
        else:
            print("  Skipped.")
    print()

    # Step 3: Environment configuration
    print("[3/5] Environment configuration")
    env_path = os.path.join(brain_path, ".env")
    existing_host_path = _read_env_value(env_path, "BRAIN_HOST_PATH")
    if os.path.isfile(env_path):
        print(f"  .env already exists. ", end="")
        if _ask("Regenerate?", default="n"):
            config = _prompt_env_config_wizard(default_host_path=existing_host_path)
            generate_env(brain_path, config)
            host_path = config.get("host_path", "")
        else:
            print("  Keeping existing .env")
            host_path = existing_host_path
    else:
        config = _prompt_env_config_wizard()
        generate_env(brain_path, config)
        host_path = config.get("host_path", "")
    print()

    # Step 4: Index
    print("[4/5] Search index")
    if md_count > 0:
        if _ask(f"  Index {md_count} notes for semantic search?", default="y"):
            _run_index(brain_path)
        else:
            print("  Skipped. Run 'brain-index run' later, or the background watcher will handle it.")
    else:
        print("  No notes to index yet. The background watcher will index as you add notes.")
    print()

    # Step 5: Done
    print("[5/5] Setup complete!")
    _print_welcome(brain_path, host_path=host_path)


def _ask_host_path(default=""):
    """Ask for the host filesystem path that is mounted as /brain."""
    print()
    print("  ── Host vault path ──")
    print("  This is the path on your host machine that you mount as /brain.")
    print("  It's saved to .env so skills can generate correct docker run commands.")
    print()
    return _ask_input("  Host path to this vault (e.g. ~/Documents/brain)", default=default)


def _prompt_env_config_wizard(default_host_path=""):
    """Preset picker + model discovery — used for both new and regenerated .env."""
    print("  The container needs to know which models to use for embeddings and chat.")
    print()
    print("  Presets:")
    for key, preset in PRESETS.items():
        print(f"    {key}) {preset['name']}")
    print(f"    5) Custom (enter endpoints manually)")
    print()

    choice = _ask_input("  Choose a preset", default="1")

    if choice in PRESETS:
        config = dict(PRESETS[choice])
        name = config.pop("name")
        print(f"  Using {name} defaults.")
        if choice == "4":
            print("  Note: You'll need to set ANTHROPIC_API_KEY in the container environment.")
            print("  Embedding/chat still need a local model (Docker Model Runner by default).")
        config["embedding_base_url"], config["embedding_model"] = _pick_embedding_model(
            config["embedding_base_url"], config["embedding_model"]
        )
    elif choice == "5":
        config = _prompt_env_config()
    else:
        print(f"  Unknown choice '{choice}', using Docker Model Runner defaults.")
        config = dict(PRESETS["1"])
        config.pop("name")
        config["embedding_base_url"], config["embedding_model"] = _pick_embedding_model(
            config["embedding_base_url"], config["embedding_model"]
        )

    _configure_claude_code_llm(config)
    _configure_brave(config)
    config["host_path"] = _ask_host_path(default_host_path)
    return config


def _prompt_env_config():
    """Prompt for each embedding/chat endpoint individually (custom preset path)."""
    dmr = "http://model-runner.docker.internal/engines/llama.cpp/v1"
    config = {
        "embedding_base_url": _ask_input("  Embedding endpoint", default=dmr),
        "embedding_model": _ask_input("  Embedding model", default="ai/mxbai-embed-large:latest"),
        "openai_api_key": "local",
    }
    return config


def _run_index(brain_path):
    """Run brain-index as a subprocess."""
    try:
        env = os.environ.copy()
        env["BRAIN_PATH"] = brain_path
        result = subprocess.run(
            ["brain-index", "run"],
            env=env,
            capture_output=True,
            text=True,
            timeout=300,
        )
        if result.returncode == 0:
            # Count indexed files from output
            print(f"  Indexing complete.")
        else:
            print(f"  Indexing returned non-zero exit code. This is OK if the embedding")
            print(f"  model is not yet available — the background watcher will retry.")
    except FileNotFoundError:
        print("  brain-index not found on PATH. Index manually: brain-index run")
    except subprocess.TimeoutExpired:
        print("  Indexing timed out (>5 min). The background watcher will continue.")


