        skills = sorted(d for d in os.listdir(skills_dir)
                       if os.path.isdir(os.path.join(skills_dir, d))) if os.path.isdir(skills_dir) else []
        if skills:
            print("  ── Host Claude Code plugin ──")
            print()
            print("  A plugin has been staged with global skills and MCP config.")
            print(f"  Skills: {', '.join(skills)}")
            print()
            print("  To install on your host machine, run these two commands:")
            print()
            print(f"    claude plugin marketplace add {display_path}/.ai")
            print(f"    claude plugin install second-brain")
            print()
            print("  This registers the brain MCP server and installs all global")
            print("  skills so Claude Code can access your brain from any project.")
            print()

    print("-" * 60)
    print()


