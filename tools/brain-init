#!/usr/bin/env python3
"""brain-init: initialise a second-brain for use with brain tools.

Copies .zk config and templates, creates .ai directory, copies .vscode
workspace config, installs vault-level skills, and optionally creates the
ACE folder structure and generates a .env configuration file.

Idempotent — safe to run multiple times.

Usage:
    brain-init [--auto] [path]

    --auto   Non-interactive mode: apply defaults, skip optional steps.
             Used by the container entrypoint on first start.
    path     Vault directory (default: $BRAIN_PATH or /brain).
"""
import json
import os
import shutil
import subprocess
import sys
import urllib.request
import urllib.error

# ---------------------------------------------------------------------------
# Source path resolution
# ---------------------------------------------------------------------------

_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
_REPO_ROOT = os.path.dirname(_SCRIPT_DIR)

_ZK_SOURCE_CANDIDATES = [
    os.path.join(_REPO_ROOT, "zk"),             # local dev
    "/usr/local/lib/brain-tools/zk",            # inside container
]
_VSCODE_SOURCE_CANDIDATES = [
    os.path.join(_REPO_ROOT, "vscode"),         # local dev
    "/usr/local/lib/brain-tools/vscode",        # inside container
]
_SKILLS_SOURCE_CANDIDATES = [
    "/usr/local/lib/brain-tools/claude-seed/skills",  # inside container
    os.path.join(_REPO_ROOT, "brain-skills"),         # local dev (vault-level)
]
_GLOBAL_SKILLS_SOURCE_CANDIDATES = [
    "/usr/local/lib/brain-tools/claude-seed/skills",  # container (both tiers merged)
    os.path.join(_REPO_ROOT, "skills"),               # local dev (global tier)
]

# Skills that belong in the vault (.claude/skills/) — the brain-skills tier
_VAULT_SKILL_NAMES = {
    "brain-capture", "brain-connect", "brain-create-effort", "brain-daily",
    "brain-effort", "brain-extract", "brain-rename", "brain-reorganise",
    "brain-surface", "brain-triage",
}

# Skills that belong on the host (~/.claude/skills/) — the global tier
_GLOBAL_SKILL_NAMES = {
    "brain-context", "brain-hygiene", "brain-project", "brain-save",
}

ACE_FOLDERS = ["Atlas", "Efforts", "Cards", "Calendar", "Sources"]

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _find_source(candidates):
    """Return the first existing directory from candidates, or None."""
    return next((p for p in candidates if os.path.isdir(p)), None)


def _is_interactive():
    """True if stdin is a TTY (not piped or run from entrypoint)."""
    return sys.stdin.isatty()


def _ask(prompt, default="y"):
    """Ask a yes/no question. Returns True for yes. Non-interactive → default."""
    suffix = " [Y/n] " if default == "y" else " [y/N] "
    try:
        answer = input(prompt + suffix).strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return default == "y"
    if not answer:
        return default == "y"
    return answer in ("y", "yes")


def _ask_input(prompt, default=""):
    """Ask for text input. Returns default if empty."""
    display = f" [{default}]" if default else ""
    try:
        answer = input(f"{prompt}{display}: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return default
    return answer or default


def _fetch_models(base_url, timeout=5):
    """Query an OpenAI-compatible /models endpoint. Returns list of model IDs or []."""
    # Normalise: strip trailing /v1 if present, then append /v1/models
    url = base_url.rstrip("/")
    if url.endswith("/v1"):
        url = url + "/models"
    else:
        url = url + "/v1/models"
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = json.loads(resp.read().decode())
            models = data.get("data", [])
            return sorted(m.get("id", "") for m in models if m.get("id"))
    except Exception:
        return []


def _pick_embedding_model(base_url, default_model):
    """Interactively pick an embedding model, querying the endpoint if reachable.

    Returns (base_url, model) — base_url may be updated if the user re-enters it.
    """
    print()
    print("  ── Embedding model ──")
    print("  The embedding model affects search quality and index size.")

    while True:
        print()
        print(f"  Checking {base_url} for available models...")

        models = _fetch_models(base_url)
        # Filter to likely embedding models, but show all if none match
        embed_keywords = ("embed", "nomic", "minilm", "bge", "gte", "e5")
        embed_models = [m for m in models if any(k in m.lower() for k in embed_keywords)]

        if embed_models:
            print(f"  Found {len(embed_models)} embedding model(s):")
            print()
            for i, m in enumerate(embed_models, 1):
                marker = " (default)" if m == default_model else ""
                print(f"    {i}) {m}{marker}")
            print()
            pick = _ask_input("  Choose a model (number or name)", default=default_model)
            try:
                idx = int(pick) - 1
                if 0 <= idx < len(embed_models):
                    return base_url, embed_models[idx]
            except ValueError:
                pass
            return base_url, pick
        elif models:
            # Endpoint reachable but no obvious embedding models — show all
            print(f"  Found {len(models)} model(s) (no obvious embedding models detected):")
            print()
            for i, m in enumerate(models, 1):
                print(f"    {i}) {m}")
            print()
            print("  Tip: look for models with 'embed' in the name.")
            pick = _ask_input("  Embedding model (number or name)", default=default_model)
            try:
                idx = int(pick) - 1
                if 0 <= idx < len(models):
                    return base_url, models[idx]
            except ValueError:
                pass
            return base_url, pick
        else:
            # Endpoint unreachable — let the user fix it or skip
            print(f"  Could not reach {base_url}")
            print()
            print("  Check that your model provider is running and the URL is correct.")
            print("  Common endpoints:")
            print("    Docker Model Runner: http://model-runner.docker.internal/engines/llama.cpp/v1")
            print("    Ollama:              http://host.docker.internal:11434/v1")
            print("    LM Studio:           http://host.docker.internal:1234/v1")
            print()
            new_url = _ask_input("  Embedding endpoint (or 'skip' to enter model name manually)", default=base_url)
            if new_url.lower() == "skip":
                print()
                print("  Common embedding models:")
                print("    mxbai-embed-large  — good general-purpose, 1024 dimensions")
                print("    nomic-embed-text   — better for dense technical content, 768 dims")
                print("    all-minilm         — lightweight and fast, 384 dims")
                print()
                model = _ask_input("  Embedding model", default=default_model)
                return base_url, model
            base_url = new_url
            # Loop back to retry with the new URL


def _count_md_files(path):
    """Count markdown files in the vault (non-recursive in hidden dirs)."""
    count = 0
    for root, dirs, files in os.walk(path):
        # Skip hidden directories
        dirs[:] = [d for d in dirs if not d.startswith(".")]
        count += sum(1 for f in files if f.endswith(".md"))
    return count


