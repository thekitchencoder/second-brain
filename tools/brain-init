def _find_source(candidates):
    """Return the first existing directory from candidates, or None."""
    return next((p for p in candidates if os.path.isdir(p)), None)


def _is_interactive():
    """True if stdin is a TTY (not piped or run from entrypoint)."""
    return sys.stdin.isatty()


def _ask(prompt, default="y"):
    """Ask a yes/no question. Returns True for yes. Non-interactive → default."""
    suffix = " [Y/n] " if default == "y" else " [y/N] "
    try:
        answer = input(prompt + suffix).strip().lower()
    except EOFError:
        print()
        return default == "y"
    if not answer:
        return default == "y"
    return answer in ("y", "yes")


def _ask_input(prompt, default=""):
    """Ask for text input. Returns default if empty."""
    display = f" [{default}]" if default else ""
    try:
        answer = input(f"{prompt}{display}: ").strip()
    except EOFError:
        print()
        return default
    return answer or default


def _fetch_models(base_url, timeout=5, auth_token=""):
    """Query an OpenAI-compatible /models endpoint. Returns (models, error_hint)."""
    # Normalise: strip trailing /v1 if present, then append /v1/models
    url = base_url.rstrip("/")
    if url.endswith("/v1"):
        url = url + "/models"
    else:
        url = url + "/v1/models"
    try:
        headers = {"Accept": "application/json"}
        if auth_token:
            headers["Authorization"] = f"Bearer {auth_token}"
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = json.loads(resp.read().decode())
            models = data.get("data", [])
            return sorted(m.get("id", "") for m in models if m.get("id")), None
    except urllib.error.HTTPError as e:
        return [], f"HTTP {e.code} {e.reason} — {url}"
    except urllib.error.URLError as e:
        return [], f"Connection failed: {e.reason} — {url}"
    except Exception as e:
        return [], f"{type(e).__name__}: {e} — {url}"


def _pick_embedding_model(base_url, default_model):
    """Interactively pick an embedding model, querying the endpoint if reachable.

    Returns (base_url, model) — base_url may be updated if the user re-enters it.
    """
    print()
    print("  ── Embedding model ──")
    print("  The embedding model affects search quality and index size.")

    while True:
        print()
        print(f"  Checking {base_url} for available models...")

        models, error = _fetch_models(base_url)
        # Filter to likely embedding models, but show all if none match
        embed_keywords = ("embed", "nomic", "minilm", "bge", "gte", "e5")
        embed_models = [m for m in models if any(k in m.lower() for k in embed_keywords)]

        if embed_models:
            effective_default = default_model if default_model in embed_models else embed_models[0]
            print(f"  Found {len(embed_models)} embedding model(s):")
            print()
            for i, m in enumerate(embed_models, 1):
                marker = " (default)" if m == effective_default else ""
                print(f"    {i}) {m}{marker}")
            print()
            pick = _ask_input("  Choose a model (number or name)", default=effective_default)
            try:
                idx = int(pick) - 1
                if 0 <= idx < len(embed_models):
                    return base_url, embed_models[idx]
            except ValueError:
                pass
            return base_url, pick
        elif models:
            # Endpoint reachable but no obvious embedding models — show all
            effective_default = default_model if default_model in models else models[0]
            print(f"  Found {len(models)} model(s) (no obvious embedding models detected):")
            print()
            for i, m in enumerate(models, 1):
                marker = " (default)" if m == effective_default else ""
                print(f"    {i}) {m}{marker}")
            print()
            print("  Tip: look for models with 'embed' in the name.")
            pick = _ask_input("  Embedding model (number or name)", default=effective_default)
            try:
                idx = int(pick) - 1
                if 0 <= idx < len(models):
                    return base_url, models[idx]
            except ValueError:
                pass
            return base_url, pick
        else:
            # Endpoint unreachable — let the user fix it or skip
            print(f"  Could not reach {base_url}" + (f": {error}" if error else ""))
            print()
            print("  Check that your model provider is running and the URL is correct.")
            print("  Common endpoints:")
            print("    Docker Model Runner: http://model-runner.docker.internal/engines/llama.cpp/v1")
            print("    Ollama:              http://host.docker.internal:11434/v1")
            print("    LM Studio:           http://host.docker.internal:1234/v1")
            print()
            new_url = _ask_input("  Embedding endpoint (or 'skip' to enter model name manually)", default=base_url)
            if new_url.lower() == "skip":
                print()
                print("  Common embedding models:")
                print("    mxbai-embed-large  — good general-purpose, 1024 dimensions")
                print("    nomic-embed-text   — better for dense technical content, 768 dims")
                print("    all-minilm         — lightweight and fast, 384 dims")
                print()
                model = _ask_input("  Embedding model", default=default_model)
                return base_url, model
            base_url = new_url
            # Loop back to retry with the new URL


def _pick_model(base_url, default_model, label="model", auth_token=""):
    """Query an OpenAI-compatible endpoint and let the user pick a model.

    Returns (base_url, model) — base_url may be updated if the user re-enters it.
    """
    while True:
        print()
        print(f"  Checking {base_url} for available models...")
        models, error = _fetch_models(base_url, auth_token=auth_token)

        if models:
            effective_default = default_model if default_model in models else models[0]
            print(f"  Found {len(models)} model(s):")
            print()
            for i, m in enumerate(models, 1):
                marker = " (default)" if m == effective_default else ""
                print(f"    {i}) {m}{marker}")
            print()
            pick = _ask_input(f"  Choose a {label} (number or name)", default=effective_default)
            try:
                idx = int(pick) - 1
                if 0 <= idx < len(models):
                    return base_url, models[idx]
            except ValueError:
                pass
            return base_url, pick
        else:
            if error and "404" in error:
                print(f"  {base_url} does not expose a model listing.")
            else:
                print(f"  Could not reach {base_url}" + (f": {error}" if error else ""))
            print()
            new_url = _ask_input(f"  Endpoint (or 'skip' to enter model name manually)", default=base_url)
            if new_url.lower() == "skip":
                model = _ask_input(f"  {label.capitalize()} model name", default=default_model)
                return base_url, model
            base_url = new_url


def _configure_claude_code_llm(config):
    """Interactively configure Claude Code's in-container LLM (Anthropic-compatible endpoint)."""
    print()
    print("  ── Claude Code LLM ──")
    print("  Configure which model Claude Code uses inside the container.")
    print("  Leave blank to use the Anthropic API directly (requires ANTHROPIC_API_KEY).")
    print()

    default_url = config.get("anthropic_base_url", "")
    default_model = config.get("anthropic_model", "")
    default_token = config.get("anthropic_auth_token", "")

    base_url = _ask_input("  LLM endpoint (blank for Anthropic API)", default=default_url)

    if base_url:
        auth_token = _ask_input("  Auth token (blank if none)", default=default_token)
        base_url, model = _pick_model(base_url, default_model, label="LLM model", auth_token=auth_token)
        config["anthropic_base_url"] = base_url
        config["anthropic_model"] = model
        config["anthropic_auth_token"] = auth_token
    else:
        config["anthropic_base_url"] = ""
        config["anthropic_model"] = ""
        config["anthropic_auth_token"] = ""


