    display_path = host_path or brain_path

    print()
    print("-" * 60)
    print()
    print("  ── Start the container ──")
    print()
    print(f"    docker run -d --name second-brain --restart unless-stopped \\")
    print(f"      -v {display_path}:/brain \\")
    print(f"      -p 7778:7778 -p 7780:7780 \\")
    print(f"      kitchencoder/second-brain:latest")
    print()
    print("  Once running:")
    print()
    print("  Open http://localhost:7778 for VS Code in the browser.")
    print("  Run 'claude' in the terminal to start a Claude Code session.")
    print()
    print("  Try these to get started:")
    print('    "Set up my brain"         — guided first-time vault setup')
    print('    "Start my day"            — create a daily note')
    print('    "Create a new effort"     — set up a project')
    print('    "I\'ve had an idea about X" — capture a thought')
