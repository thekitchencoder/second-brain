def init_core(brain_path):
    """Copy .zk, create .ai, copy .vscode — the original brain-init logic."""
    zk_source = _find_source(_ZK_SOURCE_CANDIDATES)
    if zk_source is None:
        print("Error: could not find zk config source directory.", file=sys.stderr)
        sys.exit(1)

    zk_dest = os.path.join(brain_path, ".zk")
    ai_dest = os.path.join(brain_path, ".ai")

    if os.path.isdir(zk_dest):
        # Sync new templates into existing .zk/templates/ without overwriting user edits
        src_templates = os.path.join(zk_source, "templates")
        dst_templates = os.path.join(zk_dest, "templates")
        if os.path.isdir(src_templates) and os.path.isdir(dst_templates):
            new_templates = []
            for name in os.listdir(src_templates):
                src_file = os.path.join(src_templates, name)
                dst_file = os.path.join(dst_templates, name)
                if os.path.isfile(src_file) and not os.path.exists(dst_file):
                    shutil.copy2(src_file, dst_file)
                    new_templates.append(name)
            if new_templates:
                print(f"  .zk/ exists — added {len(new_templates)} new template(s): {', '.join(sorted(new_templates))}")
            else:
                print(f"  .zk/ already exists, templates up to date.")
        else:
            print(f"  .zk/ already exists, skipping.")
    else:
        shutil.copytree(zk_source, zk_dest)
        print(f"  Created .zk/ (config + {len(os.listdir(os.path.join(zk_dest, 'templates')))} templates)")

    os.makedirs(ai_dest, exist_ok=True)
    print(f"  Ensured .ai/ exists")

    vscode_source = _find_source(_VSCODE_SOURCE_CANDIDATES)
    if vscode_source is not None:
        vscode_dest = os.path.join(brain_path, ".vscode")
        if os.path.isdir(vscode_dest):
            print(f"  .vscode/ already exists, skipping.")
        else:
            shutil.copytree(vscode_source, vscode_dest)
            print(f"  Created .vscode/ (workspace config)")


def init_vault_skills(brain_path):
    """Copy vault-level skills and CLAUDE.md into <vault>/.claude/."""
    skills_source = _find_source(_SKILLS_SOURCE_CANDIDATES)
    if skills_source is None:
        print("  No skills source found, skipping vault skills.")
        return

    dest_dir = os.path.join(brain_path, ".claude", "skills")
    os.makedirs(dest_dir, exist_ok=True)

    installed = []
    for name in sorted(_VAULT_SKILL_NAMES):
        src = os.path.join(skills_source, name)
        dst = os.path.join(dest_dir, name)
        if not os.path.isdir(src):
            continue
        if os.path.isdir(dst):
            continue
        shutil.copytree(src, dst)
        installed.append(name)

    if installed:
        print(f"  Installed {len(installed)} vault skills to .claude/skills/")
    else:
        print(f"  Vault skills already installed.")

    # Seed vault-level CLAUDE.md (filesystem extension for vault sessions)
    claude_templates = _find_source(_CLAUDE_TEMPLATES_CANDIDATES)
    if claude_templates:
        vault_claude_src = os.path.join(claude_templates, "vault-claude.md")
        vault_claude_dst = os.path.join(brain_path, ".claude", "CLAUDE.md")
        if os.path.isfile(vault_claude_src) and not os.path.isfile(vault_claude_dst):
            shutil.copy2(vault_claude_src, vault_claude_dst)
            print(f"  Seeded .claude/CLAUDE.md (vault-level instructions)")


def stage_brain_plugin(brain_path):
    """Stage a Claude Code plugin at <vault>/.ai/brain-plugin/ for host installation.

    The marketplace manifest lives one level up at <vault>/.ai/.claude-plugin/marketplace.json
    so the source path "./brain-plugin" is a valid relative reference.

    Install with:
        claude plugin marketplace add <vault>/.ai
        claude plugin install second-brain
    """
    skills_source = _find_source(_GLOBAL_SKILLS_SOURCE_CANDIDATES)
    if skills_source is None:
        return

    ai_dir = os.path.join(brain_path, ".ai")
    plugin_dir = os.path.join(ai_dir, "brain-plugin")
    manifest_dir = os.path.join(plugin_dir, ".claude-plugin")
    skills_dir = os.path.join(plugin_dir, "skills")

    os.makedirs(manifest_dir, exist_ok=True)
    os.makedirs(skills_dir, exist_ok=True)

    # Write plugin manifest
    manifest = {
        "name": "second-brain",
        "version": "1.0.0",
        "description": "Global brain skills and MCP server for second-brain",
        "author": {"name": "kitchencoder"},
    }
    manifest_path = os.path.join(manifest_dir, "plugin.json")
    with open(manifest_path, "w") as f:
        json.dump(manifest, f, indent=2)
        f.write("\n")

    # Write marketplace manifest at .ai/.claude-plugin/marketplace.json
    # so "./brain-plugin" is a valid relative path to the plugin directory.
    marketplace = {
        "name": "second-brain",
        "owner": {"name": "kitchencoder"},
        "plugins": [
            {
                "name": "second-brain",
                "source": "./brain-plugin",
                "description": "Global brain skills and MCP server for second-brain",
                "author": {"name": "kitchencoder"},
            }
        ],
    }
    marketplace_manifest_dir = os.path.join(ai_dir, ".claude-plugin")
    os.makedirs(marketplace_manifest_dir, exist_ok=True)
    marketplace_path = os.path.join(marketplace_manifest_dir, "marketplace.json")
    with open(marketplace_path, "w") as f:
        json.dump(marketplace, f, indent=2)
        f.write("\n")

    # Write MCP server config (HTTP transport)
    mcp_config = {
        "mcpServers": {
            "brain": {
                "type": "http",
                "url": "http://127.0.0.1:7780/mcp/",
            }
        }
    }
    mcp_path = os.path.join(plugin_dir, ".mcp.json")
    with open(mcp_path, "w") as f:
        json.dump(mcp_config, f, indent=2)
        f.write("\n")

    # Copy global skills into plugin
    staged = []
    for name in sorted(_GLOBAL_SKILL_NAMES):
        src = os.path.join(skills_source, name)
        dst = os.path.join(skills_dir, name)
        if not os.path.isdir(src):
            continue
        # Always overwrite (staging area, not user-edited)
        if os.path.isdir(dst):
            shutil.rmtree(dst)
        shutil.copytree(src, dst)
        staged.append(name)

    # Copy plugin-level CLAUDE.md (MCP-only guidance for host sessions)
    claude_templates = _find_source(_CLAUDE_TEMPLATES_CANDIDATES)
    if claude_templates:
        plugin_claude_src = os.path.join(claude_templates, "plugin-claude.md")
        plugin_claude_dst = os.path.join(plugin_dir, "CLAUDE.md")
        if os.path.isfile(plugin_claude_src):
            shutil.copy2(plugin_claude_src, plugin_claude_dst)

    if staged:
        print(f"  Staged brain plugin to .ai/brain-plugin/ ({len(staged)} skills + MCP config)")


def init_ace_folders(brain_path):
    """Create the ACE folder structure with .keep files."""
    created = []
    for folder in ACE_FOLDERS:
        folder_path = os.path.join(brain_path, folder)
        if not os.path.isdir(folder_path):
            os.makedirs(folder_path)
            # .keep ensures the folder is preserved in git
            keep = os.path.join(folder_path, ".keep")
            with open(keep, "w") as f:
                pass
            created.append(folder)
    if created:
        print(f"  Created folders: {', '.join(created)}")
    else:
        print(f"  All folders already exist.")


def generate_env(brain_path, config):
    """Write a .env file to the vault root."""
    env_path = os.path.join(brain_path, ".env")
    lines = [
        "# Second Brain configuration",
        "# Generated by brain-init — edit freely, changes take effect on container restart.",
        "",
        "# ── Embedding model (for semantic search) ────────────────────────────────────",
        f"EMBEDDING_BASE_URL={config['embedding_base_url']}",
        f"EMBEDDING_MODEL={config['embedding_model']}",
        f"OPENAI_API_KEY={config.get('openai_api_key', 'local')}",
        "",
        "# ── Claude Code (in-container LLM) ───────────────────────────────────────────",
    ]
    if config.get("anthropic_base_url"):
        lines.append(f"ANTHROPIC_BASE_URL={config['anthropic_base_url']}")
    if config.get("anthropic_auth_token"):
        lines.append(f"ANTHROPIC_AUTH_TOKEN={config['anthropic_auth_token']}")
    if config.get("anthropic_model"):
        lines.append(f"ANTHROPIC_MODEL={config['anthropic_model']}")
    if not config.get("anthropic_base_url"):
        lines.append("# Using Anthropic API directly (set ANTHROPIC_API_KEY in your environment)")

    lines.append("")
    lines.append("# ── Container ─────────────────────────────────────────────────────────────────")
    lines.append("# Host path on your machine mounted as /brain in the container")
    if config.get("host_path"):
        lines.append(f"BRAIN_HOST_PATH={config['host_path']}")
    else:
        lines.append("# BRAIN_HOST_PATH=~/Documents/brain")
    lines.append("")
    lines.append("# ── MCP transport ─────────────────────────────────────────────────────────────")
    lines.append("# Enable HTTP MCP transport on port 7780")
    lines.append("BRAIN_MCP_TRANSPORT=http")
    lines.append("")
    lines.append("# ── Optional ──────────────────────────────────────────────────────────────────")
    if config.get("brave_api_key"):
        lines.append(f"BRAVE_API_KEY={config['brave_api_key']}")
    else:
        lines.append("# BRAVE_API_KEY=")
    lines.append("")

    with open(env_path, "w") as f:
        f.write("\n".join(lines) + "\n")
    print(f"  Saved .env")


