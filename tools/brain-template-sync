#!/usr/bin/env python3
"""brain-template-sync: sync templates between Obsidian and zk formats.

Obsidian templates use:   {{date}}, {{time}}, {{title}}
zk templates use:         {{format-date now "2006-01-02"}}, {{format-date now "15:04:05"}}, {{title}}

Usage:
  brain-template-sync status           Show sync state of all templates
  brain-template-sync diff [name]      Show detailed diff for one or all diverged templates
  brain-template-sync obsidian-to-zk   Convert /brain/templates/ → /brain/.zk/templates/
  brain-template-sync zk-to-obsidian   Convert /brain/.zk/templates/ → /brain/templates/
"""
import os
import re
import sys
from pathlib import Path

from lib.config import Config

_cfg = Config()

OBSIDIAN_DIR = Path(_cfg.brain_path) / "templates"
ZK_DIR = Path(_cfg.brain_path) / ".zk" / "templates"

# Order matters: combined datetime must be replaced before individual date/time
_OBS_TO_ZK = [
    (r"\{\{date\}\}T\{\{time\}\}", '{{format-date now "2006-01-02T15:04:05"}}'),
    (r"\{\{date\}\}",              '{{format-date now "2006-01-02"}}'),
    (r"\{\{time\}\}",              '{{format-date now "15:04:05"}}'),
]

_ZK_TO_OBS = [
    (r'\{\{format-date now "2006-01-02T15:04:05"\}\}', "{{date}}T{{time}}"),
    (r'\{\{format-date now "2006-01-02"\}\}',          "{{date}}"),
    (r'\{\{format-date now "15:04:05"\}\}',            "{{time}}"),
]


def _convert(content: str, rules: list[tuple[str, str]]) -> tuple[str, list[str]]:
    """Apply substitution rules. Returns (converted_content, list_of_warnings)."""
    warnings = []
    for pattern, replacement in rules:
        content = re.sub(pattern, replacement, content)
    # Detect any remaining unknown Obsidian-style variables (single braces are normal YAML)
    unknowns = re.findall(r"\{\{(?!format-date|title|slug)[^}]+\}\}", content)
    if unknowns:
        warnings.append(f"unrecognised variables left unconverted: {', '.join(set(unknowns))}")
    return content, warnings


def _stem(path: Path) -> str:
    return path.stem  # filename without extension


def cmd_status() -> None:
    obs = {p.stem: p for p in OBSIDIAN_DIR.glob("*.md")} if OBSIDIAN_DIR.exists() else {}
    zk = {p.stem: p for p in ZK_DIR.glob("*.md")} if ZK_DIR.exists() else {}
    all_names = sorted(obs.keys() | zk.keys())

    print(f"{'Template':<30} {'Obsidian':^10} {'zk':^10} {'Status':<20}")
    print("-" * 72)
    diverged = []
    for name in all_names:
        o = "✓" if name in obs else "—"
        z = "✓" if name in zk else "—"
        status = ""
        if name in obs and name in zk:
            obs_content = obs[name].read_text(encoding="utf-8")
            zk_content = zk[name].read_text(encoding="utf-8")
            # Convert Obsidian → zk for comparison
            obs_converted, _ = _convert(obs_content, _OBS_TO_ZK)
            obs_converted_stripped = obs_converted.strip()
            zk_stripped = zk_content.strip()
            if obs_converted_stripped == zk_stripped:
                status = "in sync"
            else:
                # Templates differ — check if zk is the expected conversion result
                # by converting zk → Obsidian and comparing
                zk_to_obs, _ = _convert(zk_content, _ZK_TO_OBS)
                if obs_content.strip() == zk_to_obs.strip():
                    # zk is what you'd get from converting Obsidian → zk
                    # but Obsidian has been modified since zk was created
                    status = "obsidian modified"
                else:
                    # zk doesn't match what conversion would produce
                    status = "zk diverged"
                diverged.append((name, status, obs[name], zk[name]))
        elif name in obs:
            status = "zk missing"
        elif name in zk:
            status = "obsidian missing"
        print(f"{name:<30} {o:^10} {z:^10} {status:<20}")

    if diverged:
        print(f"\n{len(diverged)} template(s) diverged. Use 'brain-template-sync diff' to see details.")


def cmd_obsidian_to_zk() -> None:
    if not OBSIDIAN_DIR.exists():
        print(f"Obsidian templates directory not found: {OBSIDIAN_DIR}", file=sys.stderr)
        sys.exit(1)
    ZK_DIR.mkdir(parents=True, exist_ok=True)
    for src in sorted(OBSIDIAN_DIR.glob("*.md")):
        content, warnings = _convert(src.read_text(encoding="utf-8"), _OBS_TO_ZK)
        dest = ZK_DIR / src.name
        dest.write_text(content, encoding="utf-8")
        status = "updated" if dest.exists() else "created"
        print(f"  {status}: {dest.name}")
        for w in warnings:
            print(f"    warning: {w}")


def cmd_zk_to_obsidian() -> None:
    if not ZK_DIR.exists():
        print(f"zk templates directory not found: {ZK_DIR}", file=sys.stderr)
        sys.exit(1)
    OBSIDIAN_DIR.mkdir(parents=True, exist_ok=True)
    for src in sorted(ZK_DIR.glob("*.md")):
        content, warnings = _convert(src.read_text(encoding="utf-8"), _ZK_TO_OBS)
        dest = OBSIDIAN_DIR / src.name
        dest.write_text(content, encoding="utf-8")
        status = "updated" if dest.exists() else "created"
        print(f"  {status}: {dest.name}")
        for w in warnings:
            print(f"    warning: {w}")


def cmd_diff(name: str) -> None:
    """Show detailed diff for a specific template or all diverged templates."""
    obs = {p.stem: p for p in OBSIDIAN_DIR.glob("*.md")} if OBSIDIAN_DIR.exists() else {}
    zk = {p.stem: p for p in ZK_DIR.glob("*.md")} if ZK_DIR.exists() else {}

    if name:
        if name not in obs or name not in zk:
            print(f"Template '{name}' not found in both directories", file=sys.stderr)
            sys.exit(1)
        _show_diff(name, obs[name], zk[name])
        return

    # Show all diverged templates
    diverged = []
    for name in sorted(obs.keys() & zk.keys()):
        obs_content = obs[name].read_text(encoding="utf-8")
        zk_content = zk[name].read_text(encoding="utf-8")
        obs_converted, _ = _convert(obs_content, _OBS_TO_ZK)
        if obs_converted.strip() != zk_content.strip():
            diverged.append((name, obs[name], zk[name]))

    if not diverged:
        print("All templates in sync.")
        return

    for name, obs_path, zk_path in diverged:
        _show_diff(name, obs_path, zk_path)


def _show_diff(name: str, obs_path: Path, zk_path: Path) -> None:
    """Show side-by-side diff for a template."""
    obs_content = obs_path.read_text(encoding="utf-8")
    zk_content = zk_path.read_text(encoding="utf-8")

    # Determine which side was modified
    obs_converted, _ = _convert(obs_content, _OBS_TO_ZK)
    zk_to_obs, _ = _convert(zk_content, _ZK_TO_OBS)
    if obs_content.strip() == zk_to_obs.strip():
        side = "obsidian modified"
    elif obs_converted.strip() == zk_content.strip():
        side = "zk diverged (matches current Obsidian)"
    else:
        side = "zk diverged (custom)"

    print(f"\n{'=' * 60}")
    print(f"Template: {name} ({side})")
    print(f"{'=' * 60}")
    print(f"Obsidian: {obs_path}")
    print(f"zk:       {zk_path}")
    print()

    # Show unified diff
    import difflib
    diff = difflib.unified_diff(
        obs_content.splitlines(keepends=True),
        zk_content.splitlines(keepends=True),
        fromfile="Obsidian",
        tofile="zk",
        lineterm=""
    )
    diff_lines = list(diff)
    if diff_lines:
        print("".join(diff_lines))
    else:
        # Files are identical (both modified same way)
        print("(files are identical - both modified identically)")


def main() -> None:
    cmd = sys.argv[1] if len(sys.argv) > 1 else "status"
    if cmd == "status":
        cmd_status()
    elif cmd == "diff":
        name = sys.argv[2] if len(sys.argv) > 2 else ""
        cmd_diff(name)
    elif cmd == "obsidian-to-zk":
        print(f"Converting Obsidian → zk  ({OBSIDIAN_DIR} → {ZK_DIR})")
        cmd_obsidian_to_zk()
        print("Done.")
    elif cmd == "zk-to-obsidian":
        print(f"Converting zk → Obsidian  ({ZK_DIR} → {OBSIDIAN_DIR})")
        cmd_zk_to_obsidian()
        print("Done.")
    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
